# ===========================================
# Variables de entorno del Backend (NestJS)
# ===========================================
# Copia este archivo como .env y completa los valores

# --- Base de datos (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/proyectosaas?schema=public"

# --- Puerto del servidor ---
PORT=4000

# --- Entorno ---
NODE_ENV=development

# --- Clerk (Autenticación) ---
CLERK_SECRET_KEY=sk_test_...

# --- Cloudinary (Almacenamiento de imágenes) ---
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# --- Hetzner Storage (Almacenamiento de archivos) ---
HETZNER_S3_BUCKET=tu_bucket
HETZNER_S3_ENDPOINT=https://tu_endpoint
HETZNER_S3_ACCESS_KEY=tu_access_key
HETZNER_S3_SECRET_KEY=tu_secret_key
FILES_BASE_URL=https://tu_base_url

# --- Resend (Envío de correos) ---
RESEND_API_KEY=re_...

# --- ID de empresa (para instancias dedicadas, opcional) ---
# INSTANCE_EMPRESA_ID=uuid-de-la-empresa
